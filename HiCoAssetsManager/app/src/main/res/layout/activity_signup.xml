<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/hico_gray">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/signupToolbar" android:layout_width="match_parent"
            android:layout_height="64dp" android:background="@color/hico_yellow"
            app:title="Demande de compte" app:titleTextColor="@color/hico_black"
            app:navigationIcon="@android:drawable/ic_media_previous" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="18dp">

            <EditText android:id="@+id/signupUsernameEditText"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:hint="Nom d'utilisateur" android:singleLine="true"
                android:textColor="@color/hico_black" android:textColorHint="#777777"
                android:background="@drawable/bg_field" />

            <EditText android:id="@+id/signupPasswordEditText"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:hint="Mot de passe" android:singleLine="true"
                android:inputType="textPassword"
                android:textColor="@color/hico_black" android:textColorHint="#777777"
                android:background="@drawable/bg_field" android:layout_marginTop="12dp" />

            <Spinner android:id="@+id/signupRoleSpinner"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendRequestButton" android:layout_width="match_parent"
                android:layout_height="54dp" android:text="Envoyer la demande"
                android:textColor="@color/hico_black" android:textStyle="bold"
                android:layout_marginTop="18dp" app:backgroundTint="@color/hico_yellow"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
