<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/hico_gray">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar" android:layout_width="match_parent"
            android:layout_height="64dp" android:background="@color/hico_yellow"
            app:title="HiCo Assets Manager" app:titleTextColor="@color/hico_black" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <TextView android:id="@+id/statsTextView" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/hico_black"
                android:textStyle="bold" android:text="0 biens" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/manageUsersButton" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="Demandes utilisateurs"
                android:textColor="@color/hico_black" android:textStyle="bold"
                android:layout_marginTop="8dp" app:backgroundTint="@color/hico_yellow"
                app:cornerRadius="8dp" />

            <EditText android:id="@+id/searchEditText" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Rechercher par nom"
                android:textColor="@color/hico_black" android:textColorHint="#777777"
                android:singleLine="true" android:background="@drawable/bg_field"
                android:layout_marginTop="8dp" />

            <Spinner android:id="@+id/typeSpinner" android:layout_width="match_parent"
                android:layout_height="48dp" android:layout_marginTop="8dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/biensRecyclerView"
            android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:padding="8dp" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addFab" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="bottom|end"
        android:layout_margin="20dp" android:contentDescription="Ajouter"
        app:backgroundTint="@color/hico_yellow" app:tint="@color/hico_black"
        app:srcCompat="@android:drawable/ic_input_add" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
