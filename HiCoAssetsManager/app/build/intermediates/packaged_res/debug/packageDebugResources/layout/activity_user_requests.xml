<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/hico_gray">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/requestsToolbar" android:layout_width="match_parent"
        android:layout_height="64dp" android:background="@color/hico_yellow"
        app:title="Demandes utilisateurs" app:titleTextColor="@color/hico_black"
        app:navigationIcon="@android:drawable/ic_media_previous" />

    <TextView android:id="@+id/emptyRequestsTextView"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Aucune demande en attente" android:textColor="@color/hico_black"
        android:textStyle="bold" android:padding="16dp" android:visibility="gone" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:id="@+id/requestsContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="10dp" />
    </ScrollView>
</LinearLayout>
