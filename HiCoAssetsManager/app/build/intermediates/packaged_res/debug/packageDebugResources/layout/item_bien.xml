<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="8dp" app:cardCornerRadius="8dp"
    app:cardElevation="3dp" app:cardUseCompatPadding="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <TextView android:id="@+id/nomTextView" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/hico_black"
            android:textStyle="bold" android:textSize="18sp" />

        <TextView android:id="@+id/typeTextView" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/hico_honey"
            android:textStyle="bold" android:layout_marginTop="3dp" />

        <TextView android:id="@+id/valeurTextView" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/hico_black"
            android:layout_marginTop="3dp" />

        <TextView android:id="@+id/descriptionTextView" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#444444"
            android:layout_marginTop="6dp" />

        <LinearLayout android:id="@+id/adminActionsLayout" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:gravity="end" android:layout_marginTop="10dp">

            <Button android:id="@+id/editButton" android:layout_width="wrap_content"
                android:layout_height="42dp" android:text="Modifier" />

            <Button android:id="@+id/deleteButton" android:layout_width="wrap_content"
                android:layout_height="42dp" android:text="Supprimer"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
