<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="8dp" app:cardCornerRadius="8dp"
    app:cardElevation="3dp" app:cardUseCompatPadding="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <TextView android:id="@+id/requestUsernameTextView"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/hico_black" android:textStyle="bold"
            android:textSize="18sp" />

        <TextView android:id="@+id/requestRoleTextView"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/hico_honey" android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView android:id="@+id/requestDateTextView"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#444444" android:layout_marginTop="4dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="end" android:layout_marginTop="10dp">

            <Button android:id="@+id/approveButton" android:layout_width="wrap_content"
                android:layout_height="42dp" android:text="Accepter"
                android:textColor="@color/hico_black" />

            <Button android:id="@+id/denyButton" android:layout_width="wrap_content"
                android:layout_height="42dp" android:text="Refuser"
                android:textColor="@color/hico_black" android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
