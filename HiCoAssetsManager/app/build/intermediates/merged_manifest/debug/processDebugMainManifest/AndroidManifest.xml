<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hico.assetsmanager"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <permission
        android:name="com.hico.assetsmanager.READ_BIENS"
        android:protectionLevel="normal" />
    <permission
        android:name="com.hico.assetsmanager.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.hico.assetsmanager.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/ic_hico_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_hico_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.HiCoAssetsManager" >
        <activity android:name="com.hico.assetsmanager.AddEditBienActivity" />
        <activity android:name="com.hico.assetsmanager.UserRequestsActivity" />
        <activity android:name="com.hico.assetsmanager.SignupActivity" />
        <activity android:name="com.hico.assetsmanager.MainActivity" />
        <activity android:name="com.hico.assetsmanager.LoginActivity" />
        <activity
            android:name="com.hico.assetsmanager.SplashActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="com.hico.assetsmanager.provider.BienContentProvider"
            android:authorities="com.hico.assetsprovider"
            android:exported="true"
            android:readPermission="com.hico.assetsmanager.READ_BIENS" />

        <receiver
            android:name="com.hico.assetsmanager.receiver.BootReceiver"
            android:enabled="true"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="com.hico.assetsmanager.receiver.TimeChangeReceiver"
            android:enabled="true"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="com.hico.assetsmanager.receiver.BienRequestReceiver"
            android:enabled="true"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.hico.assetsmanager.REQUEST_BIEN" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.hico.assetsmanager.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>